rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Decision validation
    function isValidDecision(data) {
      return data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 500 &&
             data.analysisType in ['pros_cons', 'swot', 'comparison'] &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /decisions/{decisionId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      isValidId(decisionId) && 
                      isValidDecision(incoming()) &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;
                      
      allow update: if isOwner(existing().userId) &&
                      isValidDecision(incoming()) &&
                      incoming().updatedAt == request.time &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().userId == existing().userId;
                      
      allow delete: if isOwner(existing().userId);
    }
  }
}
